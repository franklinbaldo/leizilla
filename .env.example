# Configurações do Leizilla

# Internet Archive (obrigatório para upload)
IA_ACCESS_KEY=your_access_key_here
IA_SECRET_KEY=your_secret_key_here

# Chave LLM para o parse (RFC-0006) — uma chave basta (Gemini OU Anthropic OU OpenAI)
# GEMINI_API_KEY=your_gemini_key_here      # ou GOOGLE_API_KEY
# ANTHROPIC_API_KEY=your_anthropic_key_here  # opcional — uma chave LLM basta

# Modelo LiteLLM do parse (opcional; default automático pela chave disponível)
# LLM_MODEL=gemini/gemini-2.5-flash

# Configurações do Crawler (opcional)
CRAWLER_DELAY=2000          # ms entre requests
CRAWLER_RETRIES=3           # tentativas em caso de falha
CRAWLER_TIMEOUT=30000       # timeout em ms

# Configurações do DuckDB (opcional)
DUCKDB_PATH=data/leizilla.duckdb  # caminho do banco local